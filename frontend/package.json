{
  "name": "crawler-frontend",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "vue-tsc --noEmit -p tsconfig.json && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 5173",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --ext .ts,.vue --max-warnings=0",
    "lint:fix": "eslint . --ext .ts,.vue --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css,json}\"",
    "gen-types": "openapi-typescript http://localhost:8001/openapi.json -o src/api/openapi.d.ts"
  },
  "dependencies": {
    "@vueuse/core": "^11.2.0",
    "@vueuse/integrations": "^11.2.0",
    "@vueuse/math": "^11.2.0",
    "@tanstack/vue-query": "^5.59.16",
    "@tanstack/vue-table": "^8.20.5",
    "axios": "^1.7.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "echarts": "^5.5.1",
    "lucide-vue-next": "^0.460.0",
    "pinia": "^2.2.6",
    "radix-vue": "^1.9.11",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "vee-validate": "^4.14.5",
    "vue": "^3.5.13",
    "vue-echarts": "^7.0.3",
    "vue-i18n": "^10.0.4",
    "vue-router": "^4.4.5",
    "vue-sonner": "^1.2.4"
  },
  "devDependencies": {
    "@iconify/json": "^2.2.268",
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.31.0",
    "openapi-typescript": "^7.4.2",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "unplugin-auto-import": "^0.18.4",
    "unplugin-vue-components": "^0.27.4",
    "vite": "^5.4.11",
    "vue-eslint-parser": "^10.0.0",
    "globals": "^15.12.0",
    "vue-tsc": "^2.1.10"
  },
  "packageManager": "pnpm@9.12.0"
}