# ===== Application =====
APP_ENV=development
APP_NAME=crawler
APP_LOG_LEVEL=INFO
APP_SENTRY_DSN=

# ===== API server =====
API_HOST=0.0.0.0
API_PORT=8001
API_WORKERS=1
API cors.allow_origins=http://localhost:5173,http://localhost:8001
API cors.allow_credentials=true
API public_base_url=http://localhost:8001

# ===== PostgreSQL =====
POSTGRES_USER=crawler
POSTGRES_PASSWORD=changeme
POSTGRES_DB=crawler
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://crawler:changeme@postgres:5432/crawler
PG_SCHEMA=public

# ===== Redis =====
REDIS_URL=redis://redis:6379/0
REDIS_NAMESPACE=crawler

# ===== Celery =====
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_SOFT_TIME_LIMIT=3300
CELERY_TASK_TIME_LIMIT=3600

# ===== Auth (JWT RS256) =====
AUTH_PRIVATE_KEY_PATH=./secrets/jwt_rs256.pem
AUTH_PUBLIC_KEY_PATH=./secrets/jwt_rs256.pub.pem
AUTH_ACCESS_TOKEN_TTL_MIN=15
AUTH_REFRESH_TOKEN_TTL_DAYS=7
AUTH_PASSWORD_SCHEMES=argon2

# ===== Crawler engine defaults =====
CRAWLER_USER_AGENT=crawler-bot/1.0 (+https://github.com/your-org/crawler; contact: your-email@example.com)
CRAWLER_DOWNLOAD_TIMEOUT=30
CRAWLER_MAX_RETRIES=3
CRAWLER_BACKOFF_CAP=60
CRAWLER_CONCURRENCY=5
CRAWLER_MIN_DELAY=1.0
CRAWLER_MAX_DELAY=3.0
CRAWLER_MIN_CONTENT_LENGTH=200
CRAWLER_BROWSER_POOL_SIZE=2
CRAWLER_PROXY_TIMEOUT=10
CRAWLER_PROXY_FAIL_THRESHOLD=3
CRAWLER_PROXY_BLACKLIST_TTL=300

# ===== Cloudflare / antibot =====
ANTIBOT_CLOUDFLARE_MAX_RETRIES=2
ANTIBOT_USE_FAKE_USERAGENT=true
ANTIBOT_USE_CLOUDSCRAPER=true
ANTIBOT_TEST_TARGET_URL=

# ===== Webhooks =====
WEBHOOK_DELIVERY_MAX_ATTEMPTS=5
WEBHOOK_DELIVERY_TIMEOUT=15

# ===== Auto-detect (LLM, mặc định off) =====
LLM_ENABLED=false
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# ===== Frontend (Vite dev) =====
VITE_API_BASE_URL=http://localhost:8001
VITE_SENTRY_DSN=

# ===== S3/MinIO (cho Excel export lớn) =====
S3_ENDPOINT=
S3_BUCKET=crawler-exports
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1