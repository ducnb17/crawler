# ===== Production environment =====
# Copy to .env.prod and edit secrets before deploying.

# Application
APP_ENV=production
APP_NAME=crawler
APP_LOG_LEVEL=INFO

# API server (inside container)
API_HOST=0.0.0.0
API_PORT=8001
API_WORKERS=2
API_PUBLIC_BASE_URL=http://209.159.153.62:8082
API cors.allow_origins=http://209.159.153.62:8082,http://localhost:5173
API cors.allow_credentials=true

# PostgreSQL — CHANGE PASSWORD
POSTGRES_USER=crawler
POSTGRES_PASSWORD=ChangeMeStrongPass_2026
POSTGRES_DB=crawler
PG_SCHEMA=public

# Redis
REDIS_NAMESPACE=crawler

# Celery
CELERY_WORKER_CONCURRENCY=2
CELERY_TASK_SOFT_TIME_LIMIT=3300
CELERY_TASK_TIME_LIMIT=3600

# Auth (JWT RS256) — keys are mounted from backend/secrets
AUTH_ACCESS_TOKEN_TTL_MIN=15
AUTH_REFRESH_TOKEN_TTL_DAYS=7
AUTH_PASSWORD_SCHEMES=argon2

# Crawler engine
CRAWLER_CONCURRENCY=5
CRAWLER_BROWSER_POOL_SIZE=2

# Anti-bot
ANTIBOT_USE_FAKE_USERAGENT=true
ANTIBOT_USE_CLOUDSCRAPER=true

# Frontend
VITE_API_BASE_URL=/